int maxSubarrayLength(vector<int>& arr, int k)
//-------------------
{
    int i = 0;
    int j = 0;
    map<int,int> mp;
    int ans = INT_MIN;
    int n = arr.size();
    while(j<n) {

        mp[arr[j]]++;

        while(mp[arr[j]]>k){
            mp[arr[i]]--;
            i++;
        }
        ans = max(ans, j-i+1);
        j++;
    }
    return ans;
}
